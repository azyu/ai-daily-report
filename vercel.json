{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    {
      "source": "/reports/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Discordbot|Slackbot(?:-LinkExpanding)?|Twitterbot|facebookexternalhit|LinkedInBot|WhatsApp|TelegramBot|SkypeUriPreview|Googlebot|bingbot).*"
        }
      ],
      "destination": "/api/report-preview?date=$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
