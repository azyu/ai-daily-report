{
  "name": "ai-daily-report-serverless",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "build:frontend": "npm --prefix frontend run build",
    "build:server": "tsc -p tsconfig.server.json",
    "postinstall": "prisma generate --schema api/prisma/schema.prisma",
    "prepare": "husky",
    "start:container": "node server-dist/server/index.js",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "prisma:generate": "prisma generate --schema api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema api/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/functions": "^3.4.3",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "husky": "^9.1.7",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
