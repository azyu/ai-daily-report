{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "server/**/*.ts"
  ],
  "exclude": [
    "api/**/*.test.ts",
    "server/**/*.test.ts",
    "frontend/**",
    "backend/**"
  ]
}
